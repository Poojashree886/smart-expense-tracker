{
  "properties": [
    {
      "name": "jwt.secret",
      "type": "java.lang.String",
      "description": "Secret key for JWT token generation"
    },
    {
      "name": "jwt.expiration",
      "type": "java.lang.Long",
      "description": "JWT token expiration time in milliseconds"
    },
    {
      "name": "app.email.from",
      "type": "java.lang.String",
      "description": "Email address used as sender"
    },
    {
      "name": "app.email.alerts-enabled",
      "type": "java.lang.Boolean",
      "description": "Enable or disable email alerts"
    },
    {
      "name": "app.email.budget-threshold",
      "type": "java.lang.Integer",
      "description": "Percentage threshold for budget warnings"
    }
  ]
}